# ===========================================
# Isaac Sim / Isaac Lab 渲染输出
# ===========================================
# 渲染输出目录
renders/
# Videos
**/*.mp4
**/*.avi
**/*.mov
# Video frames and images
videos/**/
videos/**/*
# Capture 和 frames 输出 (任意层级)
**/capture/
**/capture/*
**/frames/
**/frames/*
**/*_frames/
**/*_frames/*
**/orbit_frames/
**/orbit_frames/*
**/_ordered/
**/_ordered/*
# Manifest 和 metadata
videos/manifest.json
videos/metadata.txt
renders/**/manifest.json
renders/**/metadata.txt

# ===========================================
# Docker 容器日志 (Isaac Sim 运行时)
# ===========================================
*.log
logs/
*.dmp

# ===========================================
# 大型 USD 资产 (本地 symlink 或缓存)
# ===========================================
# assets/scenes/  # 取消注释如果需要忽略本地场景缓存

# ===========================================
# Python
# ===========================================
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# ===========================================
